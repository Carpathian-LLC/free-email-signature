# ------------------------------------------------------------------------------------
# Free Email Signature Generator - Environment Configuration
# ------------------------------------------------------------------------------------
# Copy this file to keys.env and fill in your values.
# keys.env is git-ignored and will never be committed.
# ------------------------------------------------------------------------------------

# ── Frontend ─────────────────────────────────────────────────────────
VITE_SITE_URL=https://url.com
VITE_API_URL=http://localhost:5001

# ── Backend ──────────────────────────────────────────────────────────
FRONTEND_PORT=5000
BACKEND_PORT=5001
ALLOWED_ORIGINS=http://localhost:5000
COS_SALT=generate-a-random-string-here
MAX_UPLOAD_BYTES=2097152
MAX_IMAGE_DIMENSION=2000
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=5
TRUST_PROXY=false

# ── Database ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=db_emailgen
DB_POOL_SIZE=5
DB_SSL=true
DB_SSL_CA=
DB_SSL_CERT=
DB_SSL_KEY=
